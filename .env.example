# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional - Claude model selection
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional - Server
PORT=3000

# Optional - Scheduler (cron expression)
# Default: '0 9 * * 1' (Monday 9AM)
PIPELINE_CRON=0 9 * * 1
TIMEZONE=America/New_York

# Optional - Paths
RESOURCES_PATH=./resources
DATA_PATH=./data

# Optional - Pipeline behavior
THEME_LOOKBACK=2

# AI Scoring providers (used for photo selection)
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# S3 - Photo storage (required for publishing)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=ray-matthews-photos

# Local photo directory
PHOTOS_PATH=./photos

# Meta Graph API - Social publishing
META_PAGE_ACCESS_TOKEN=...
FACEBOOK_PAGE_ID=...
INSTAGRAM_USER_ID=...
META_API_VERSION=v21.0
