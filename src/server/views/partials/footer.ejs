  </main>

  <script>
    async function apiAction(url, method = 'POST', body = null) {
      try {
        const opts = { method, headers: { 'Content-Type': 'application/json' } };
        if (body) opts.body = JSON.stringify(body);
        const res = await fetch(url, opts);
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Request failed');
        return data;
      } catch (err) {
        alert('Error: ' + err.message);
        throw err;
      }
    }

    async function approvePost(id) {
      await apiAction(`/api/posts/${id}/approve`);
      window.location.reload();
    }

    async function rejectPost(id) {
      if (!confirm('Reject this post?')) return;
      await apiAction(`/api/posts/${id}/reject`);
      window.location.reload();
    }

    async function regeneratePost(id, btn) {
      if (!confirm('Regenerate caption for this post? The current caption will be discarded.')) return;
      btn.disabled = true;
      btn.textContent = 'Generating...';
      try {
        await apiAction(`/api/posts/${id}/regenerate`);
        window.location.reload();
      } catch {
        btn.disabled = false;
        btn.textContent = 'Regenerate';
      }
    }

    function startEditCaption(id) {
      document.getElementById(`caption-display-${id}`).classList.add('hidden');
      document.getElementById(`edit-btn-${id}`).classList.add('hidden');
      document.getElementById(`caption-edit-${id}`).classList.remove('hidden');
      document.getElementById(`caption-textarea-${id}`).focus();
    }

    function cancelEditCaption(id) {
      document.getElementById(`caption-edit-${id}`).classList.add('hidden');
      document.getElementById(`caption-display-${id}`).classList.remove('hidden');
      document.getElementById(`edit-btn-${id}`).classList.remove('hidden');
      // Reset textarea to current display value
      document.getElementById(`caption-textarea-${id}`).value =
        document.getElementById(`caption-display-${id}`).textContent;
    }

    async function saveCaption(id) {
      const caption = document.getElementById(`caption-textarea-${id}`).value;
      await apiAction(`/api/posts/${id}/caption`, 'PUT', { caption });
      document.getElementById(`caption-display-${id}`).innerHTML = caption.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      cancelEditCaption(id);
    }

    async function publishPost(id, platforms, btn) {
      const names = platforms.join(' & ');
      if (!confirm(`Publish this post to ${names}?`)) return;
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Publishing...';
      try {
        await apiAction(`/api/posts/${id}/publish`, 'POST', { platforms });
        window.location.reload();
      } catch {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    }

    async function runPipeline(btn) {
      btn.disabled = true;
      btn.textContent = 'Generating...';
      try {
        const searchInput = document.getElementById('search-terms-input');
        const searchTerms = searchInput ? searchInput.value.trim() : '';
        const body = searchTerms ? { searchTerms } : null;
        await apiAction('/api/pipeline/run', 'POST', body);
        window.location.href = '/?status=pending';
      } catch {
        btn.disabled = false;
        btn.textContent = 'Generate New Post';
      }
    }

    async function selectCandidate(id, filename, btn) {
      if (!confirm('Select this photo and generate a new caption for it?')) return;
      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Generating caption...';
      try {
        await apiAction(`/api/posts/${id}/select-candidate`, 'POST', { filename });
        window.location.reload();
      } catch {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    }

    function switchCandidateTab(postId, activeIdx) {
      const container = document.getElementById(`candidates-${postId}`);
      if (!container) return;
      // Update all tabs and panels for this post
      container.querySelectorAll('[id^="panel-"]').forEach(panel => panel.classList.add('hidden'));
      container.querySelectorAll('[id^="tab-"]').forEach(tab => {
        tab.classList.remove('text-brand-700', 'bg-brand-50', 'border-b-2', 'border-brand-600');
        tab.classList.add('text-gray-500');
      });
      const activePanel = document.getElementById(`panel-${postId}-${activeIdx}`);
      const activeTab = document.getElementById(`tab-${postId}-${activeIdx}`);
      if (activePanel) activePanel.classList.remove('hidden');
      if (activeTab) {
        activeTab.classList.remove('text-gray-500');
        activeTab.classList.add('text-brand-700', 'bg-brand-50', 'border-b-2', 'border-brand-600');
      }
    }
  </script>
</body>
</html>
