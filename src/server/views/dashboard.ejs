<%- include('partials/header') %>

<!-- Stats Bar -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
    <div class="text-2xl font-bold text-gray-900"><%= stats.total %></div>
    <div class="text-xs text-gray-500 uppercase tracking-wider">Total Photos</div>
  </div>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
    <div class="text-2xl font-bold text-green-600"><%= stats.remaining %></div>
    <div class="text-xs text-gray-500 uppercase tracking-wider">Available</div>
  </div>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
    <div class="text-2xl font-bold text-yellow-600"><%= stats.pending %></div>
    <div class="text-xs text-gray-500 uppercase tracking-wider">Pending Review</div>
  </div>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
    <div class="text-2xl font-bold text-brand-600"><%= stats.approved %></div>
    <div class="text-xs text-gray-500 uppercase tracking-wider">Approved</div>
  </div>
</div>

<!-- Actions + Tabs -->
<div class="flex items-center justify-between mb-4">
  <div class="flex gap-1">
    <a href="/?status=pending"
       class="px-4 py-2 rounded-md text-sm font-medium transition-colors
              <%= activeTab === 'pending' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200' %>">
      Pending (<%= stats.pending %>)
    </a>
    <a href="/?status=approved"
       class="px-4 py-2 rounded-md text-sm font-medium transition-colors
              <%= activeTab === 'approved' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200' %>">
      Approved (<%= stats.approved %>)
    </a>
    <a href="/?status=rejected"
       class="px-4 py-2 rounded-md text-sm font-medium transition-colors
              <%= activeTab === 'rejected' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200' %>">
      Rejected (<%= stats.rejected %>)
    </a>
  </div>
  <button onclick="runPipeline(this)"
          class="px-4 py-2 text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 rounded-md transition-colors">
    Generate New Post
  </button>
</div>

<!-- Post List -->
<% if (posts.length === 0) { %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
    <p class="text-gray-500 text-lg">No <%= activeTab %> posts yet.</p>
    <% if (activeTab === 'pending') { %>
      <p class="text-gray-400 text-sm mt-2">Click "Generate New Post" to create one.</p>
    <% } %>
  </div>
<% } else { %>
  <% for (const post of posts) { %>
    <%- include('partials/post-card', { post }) %>
  <% } %>
<% } %>

<%- include('partials/footer') %>
