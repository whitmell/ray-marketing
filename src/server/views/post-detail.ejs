<%- include('partials/header') %>

<div class="mb-4">
  <a href="/?status=<%= post.status %>" class="text-sm text-brand-600 hover:text-brand-700">&larr; Back to dashboard</a>
</div>

<%- include('partials/post-card', { post }) %>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mt-4">
  <h4 class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-3">Photo Tags</h4>
  <div class="flex flex-wrap gap-1.5">
    <% for (const tag of post.photoTags) { %>
      <span class="inline-block px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-600"><%= tag %></span>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
